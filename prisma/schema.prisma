generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SHOP_OWNER
  RIDER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING_APPROVAL
}

enum ShopStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum RiderStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum DeliveryMode {
  REDKS_DELIVERY
  SELF_DELIVERY
  BOTH
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PACKED
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentMethod {
  COD
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
  CANCELLED
}

enum RequestStatus {
  OPEN
  QUOTED
  ACCEPTED
  FULFILLED
  CANCELLED
}

model User {
  id             String           @id @default(cuid())
  phone          String           @unique
  email          String?          @unique
  name           String?
  roles          Role[]           @default([CUSTOMER])
  status         UserStatus       @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  addresses      Address[]
  ownedShops     Shop[]           @relation("ShopOwner")
  riderProfile   RiderProfile?
  orders         Order[]          @relation("CustomerOrders")
  reviews        Review[]
  itemRequests   ItemRequest[]
  notifications  Notification[]
  approvedShops  Shop[]           @relation("ShopApprovedBy")
  approvedRiders RiderProfile[]   @relation("RiderApprovedBy")
}

model Address {
  id          String      @id @default(cuid())
  userId      String
  type        AddressType @default(HOME)
  label       String?
  line1       String
  line2       String?
  landmark    String?
  cityId      String
  zoneId      String?
  pincode     String
  latitude    Decimal?    @db.Decimal(10, 7)
  longitude   Decimal?    @db.Decimal(10, 7)
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])
  city        City        @relation(fields: [cityId], references: [id])
  zone        Zone?       @relation(fields: [zoneId], references: [id])
  orders      Order[]

  @@index([userId])
  @@index([cityId, zoneId])
}

model City {
  id          String    @id @default(cuid())
  name        String
  state       String
  slug        String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  zones       Zone[]
  addresses   Address[]
  shops       Shop[]
  riderProfiles RiderProfile[]
  requests    ItemRequest[]

  @@unique([name, state])
}

model Zone {
  id                  String    @id @default(cuid())
  cityId              String
  name                String
  slug                String
  isActive            Boolean   @default(true)
  baseDeliveryFee     Decimal   @default(30) @db.Decimal(10, 2)
  freeDeliveryAbove   Decimal?  @db.Decimal(10, 2)
  estimatedMinutesMin Int       @default(20)
  estimatedMinutesMax Int       @default(45)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  city                City      @relation(fields: [cityId], references: [id])
  addresses           Address[]
  shops               Shop[]
  riderProfiles       RiderProfile[]
  requests            ItemRequest[]

  @@unique([cityId, slug])
  @@index([cityId])
}

model Shop {
  id                         String        @id @default(cuid())
  ownerId                    String
  cityId                     String
  zoneId                     String
  name                       String
  slug                       String
  description                String?
  phone                      String
  email                      String?
  addressLine1               String
  addressLine2               String?
  landmark                   String?
  pincode                    String
  latitude                   Decimal?      @db.Decimal(10, 7)
  longitude                  Decimal?      @db.Decimal(10, 7)
  status                     ShopStatus    @default(PENDING_APPROVAL)
  deliveryMode               DeliveryMode  @default(REDKS_DELIVERY)
  defaultCommissionPercent   Decimal       @default(10) @db.Decimal(5, 2)
  minOrderAmount             Decimal       @default(0) @db.Decimal(10, 2)
  opensAt                    String?
  closesAt                   String?
  approvedById               String?
  approvedAt                 DateTime?
  rejectionReason            String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  owner                      User          @relation("ShopOwner", fields: [ownerId], references: [id])
  city                       City          @relation(fields: [cityId], references: [id])
  zone                       Zone          @relation(fields: [zoneId], references: [id])
  approvedBy                 User?         @relation("ShopApprovedBy", fields: [approvedById], references: [id])
  products                   Product[]
  categories                 ShopCategory[]
  categoryCommissions        ShopCategoryCommission[]
  orders                     Order[]
  reviews                    Review[]
  itemRequests               ItemRequest[]

  @@unique([cityId, slug])
  @@index([ownerId])
  @@index([cityId, zoneId])
  @@index([status])
}

model Category {
  id                        String                   @id @default(cuid())
  name                      String
  slug                      String                   @unique
  parentId                  String?
  defaultCommissionPercent  Decimal                  @default(10) @db.Decimal(5, 2)
  isActive                  Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  parent                    Category?                @relation("CategoryTree", fields: [parentId], references: [id])
  children                  Category[]               @relation("CategoryTree")
  products                  Product[]
  shops                     ShopCategory[]
  shopCommissions           ShopCategoryCommission[]
}

model ShopCategory {
  shopId      String
  categoryId  String
  createdAt   DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@id([shopId, categoryId])
}

model ShopCategoryCommission {
  id                  String    @id @default(cuid())
  shopId              String
  categoryId          String
  commissionPercent   Decimal   @db.Decimal(5, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  shop                Shop      @relation(fields: [shopId], references: [id])
  category            Category  @relation(fields: [categoryId], references: [id])

  @@unique([shopId, categoryId])
}

model Product {
  id              String        @id @default(cuid())
  shopId          String
  categoryId      String
  name            String
  slug            String
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  mrp             Decimal?      @db.Decimal(10, 2)
  stock           Int           @default(0)
  unit            String        @default("piece")
  imageUrl        String?
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shop            Shop          @relation(fields: [shopId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([categoryId])
  @@index([status])
}

model RiderProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  cityId             String
  zoneId             String?
  status             RiderStatus   @default(PENDING_APPROVAL)
  vehicleType        String?
  vehicleNumber      String?
  drivingLicenseUrl  String?
  approvedById       String?
  approvedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id])
  city               City          @relation(fields: [cityId], references: [id])
  zone               Zone?         @relation(fields: [zoneId], references: [id])
  approvedBy         User?         @relation("RiderApprovedBy", fields: [approvedById], references: [id])
  deliveries         Delivery[]
}

model Order {
  id                  String         @id @default(cuid())
  orderNumber         String         @unique
  customerId          String
  shopId              String
  addressId           String
  status              OrderStatus    @default(PLACED)
  paymentMethod       PaymentMethod  @default(COD)
  paymentStatus       PaymentStatus  @default(PENDING)
  subtotal            Decimal        @db.Decimal(10, 2)
  deliveryFee         Decimal        @default(0) @db.Decimal(10, 2)
  discountAmount      Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal        @db.Decimal(10, 2)
  commissionPercent   Decimal        @default(10) @db.Decimal(5, 2)
  commissionAmount    Decimal        @default(0) @db.Decimal(10, 2)
  customerNote        String?
  cancellationReason  String?
  placedAt            DateTime       @default(now())
  deliveredAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  customer            User           @relation("CustomerOrders", fields: [customerId], references: [id])
  shop                Shop           @relation(fields: [shopId], references: [id])
  address             Address        @relation(fields: [addressId], references: [id])
  items               OrderItem[]
  delivery            Delivery?
  payment             Payment?
  review              Review?

  @@index([customerId])
  @@index([shopId])
  @@index([status])
  @@index([placedAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  name        String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Delivery {
  id                  String          @id @default(cuid())
  orderId             String          @unique
  riderId             String?
  status              DeliveryStatus  @default(PENDING)
  pickupOtp           String?
  dropOtp             String?
  assignedAt          DateTime?
  pickedUpAt          DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  order               Order           @relation(fields: [orderId], references: [id])
  rider               RiderProfile?   @relation(fields: [riderId], references: [id])

  @@index([riderId])
  @@index([status])
}

model Payment {
  id                String         @id @default(cuid())
  orderId           String         @unique
  method            PaymentMethod
  status            PaymentStatus  @default(PENDING)
  provider          String?
  providerPaymentId String?
  amount            Decimal        @db.Decimal(10, 2)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  order             Order          @relation(fields: [orderId], references: [id])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  title      String
  body       String
  channel    String    @default("IN_APP")
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id         String    @id @default(cuid())
  orderId    String    @unique
  shopId     String
  userId     String
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  order      Order     @relation(fields: [orderId], references: [id])
  shop       Shop      @relation(fields: [shopId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId])
}

model ItemRequest {
  id           String        @id @default(cuid())
  customerId   String
  cityId       String
  zoneId       String?
  shopId       String?
  description  String
  status       RequestStatus @default(OPEN)
  quotedAmount Decimal?      @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  customer     User          @relation(fields: [customerId], references: [id])
  city         City          @relation(fields: [cityId], references: [id])
  zone         Zone?         @relation(fields: [zoneId], references: [id])
  shop         Shop?         @relation(fields: [shopId], references: [id])

  @@index([customerId])
  @@index([cityId, zoneId])
  @@index([status])
}
