generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SHOP_OWNER
  RIDER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING_APPROVAL
}

enum ShopStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  CHANGES_REQUESTED
}

enum RiderStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  CHANGES_REQUESTED
}

enum DeliveryMode {
  REDKS
  SELF
  HYBRID
  REDKS_DELIVERY
  SELF_DELIVERY
  BOTH
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ShopDocumentType {
  GST
  FSSAI
  UDYAM
  PAN
  AADHAAR
  SHOP_PHOTO
  OWNER_PHOTO
  OTHER
}

enum ShopDocumentStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum VerificationDocumentOwnerType {
  SHOP
  RIDER
  SHOP_RIDER
  PRODUCT
}

enum VerificationDocumentType {
  GST
  FSSAI
  UDYAM
  PAN
  AADHAAR
  DRIVING_LICENSE
  VEHICLE_RC
  INSURANCE
  SELFIE
  PROFILE_PHOTO
  SHOP_PHOTO
  OWNER_PHOTO
  PRODUCT_PHOTO
  OTHER
}

enum VerificationDocumentStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ShopRiderStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  CHANGES_REQUESTED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DELETED
}

enum OrderStatus {
  PLACED
  CONFIRMED
  ACCEPTED
  REJECTED
  PACKING
  PACKED
  READY_FOR_PICKUP
  ASSIGNED
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUND_INITIATED
  REFUNDED
}

enum PaymentMethod {
  COD
  ONLINE
}

enum PaymentStatus {
  PENDING
  INITIATED
  AUTHORIZED
  PAID
  FAILED
  REFUND_PENDING
  REFUNDED
  COD_PENDING
  COD_COLLECTED
}

enum DeliveryStatus {
  PENDING
  SEARCHING_RIDER
  ASSIGNED
  ARRIVED_AT_SHOP
  PICKED_UP
  IN_TRANSIT
  ARRIVED_AT_CUSTOMER
  DELIVERED
  FAILED
  CANCELLED
  RETURNED
}

enum RiderAvailabilityStatus {
  OFFLINE
  ONLINE
  BUSY
  AVAILABLE
  ON_DELIVERY
}

enum RiderAssignmentAttemptStatus {
  OFFERED
  ACCEPTED
  REJECTED
  EXPIRED
  SKIPPED
}

enum ItemRequestStatus {
  OPEN
  IN_REVIEW
  ACCEPTED
  QUOTED
  FULFILLED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

model User {
  id                String                 @id @default(cuid())
  phone             String                 @unique
  email             String?                @unique
  name              String?
  roles             UserRole[]             @default([CUSTOMER])
  status            UserStatus             @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  addresses         Address[]
  ownedShops        Shop[]                 @relation("ShopOwner")
  riderProfile      RiderProfile?
  orders            Order[]                @relation("CustomerOrders")
  reviews           Review[]
  itemRequests      ItemRequest[]
  notifications     Notification[]
  approvedShops     Shop[]                 @relation("ShopApprovedBy")
  approvedRiders    RiderProfile[]         @relation("RiderApprovedBy")
  shopRiders        ShopRider[]
  reviewedDocuments VerificationDocument[]

  @@index([phone])
  @@index([roles], type: Gin)
  @@index([status])
}

model Address {
  id        String      @id @default(cuid())
  userId    String
  type      AddressType @default(HOME)
  label     String?
  line1     String
  line2     String?
  landmark  String?
  cityId    String
  zoneId    String?
  pincode   String
  latitude  Decimal?    @db.Decimal(10, 7)
  longitude Decimal?    @db.Decimal(10, 7)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  city      City        @relation(fields: [cityId], references: [id])
  zone      Zone?       @relation(fields: [zoneId], references: [id])
  orders    Order[]

  @@index([userId])
  @@index([cityId, zoneId])
}

model City {
  id            String         @id @default(cuid())
  name          String
  state         String
  slug          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  zones         Zone[]
  addresses     Address[]
  shops         Shop[]
  riderProfiles RiderProfile[]
  requests      ItemRequest[]

  @@unique([name, state])
}

model Zone {
  id                  String         @id @default(cuid())
  cityId              String
  name                String
  slug                String
  isActive            Boolean        @default(true)
  baseDeliveryFee     Decimal        @default(30) @db.Decimal(10, 2)
  freeDeliveryAbove   Decimal?       @db.Decimal(10, 2)
  estimatedMinutesMin Int            @default(20)
  estimatedMinutesMax Int            @default(45)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  city                City           @relation(fields: [cityId], references: [id])
  addresses           Address[]
  shops               Shop[]
  riderProfiles       RiderProfile[]
  requests            ItemRequest[]

  @@unique([cityId, slug])
  @@index([cityId])
  @@index([cityId, isActive])
}

model Shop {
  id                       String                   @id @default(cuid())
  ownerId                  String
  cityId                   String
  zoneId                   String
  categoryId               String?
  ownerName                String?
  ownerPhone               String?
  shopName                 String?
  name                     String
  slug                     String
  description              String?
  phone                    String
  email                    String?
  addressLine1             String
  addressLine2             String?
  landmark                 String?
  pincode                  String
  latitude                 Decimal?                 @db.Decimal(10, 7)
  longitude                Decimal?                 @db.Decimal(10, 7)
  shopPhotoUrl             String?
  ownerPhotoUrl            String?
  upiId                    String?
  gstNumber                String?
  fssaiNumber              String?
  udyamNumber              String?
  panNumber                String?
  status                   ShopStatus               @default(PENDING_APPROVAL)
  verificationStatus       VerificationStatus       @default(PENDING)
  deliveryMode             DeliveryMode             @default(REDKS_DELIVERY)
  deliveryRadiusKm         Decimal?                 @db.Decimal(6, 2)
  defaultCommissionPercent Decimal                  @default(10) @db.Decimal(5, 2)
  commissionPercent        Decimal                  @default(10) @db.Decimal(5, 2)
  minOrderAmount           Decimal                  @default(0) @db.Decimal(10, 2)
  minOrderValue            Decimal                  @default(0) @db.Decimal(10, 2)
  opensAt                  String?
  closesAt                 String?
  openingTime              String?
  closingTime              String?
  weeklyOffDay             String?
  approvedById             String?
  approvedAt               DateTime?
  rejectionReason          String?
  reviewNotes              String?
  changesRequestedAt       DateTime?
  submittedAt              DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  owner                    User                     @relation("ShopOwner", fields: [ownerId], references: [id])
  city                     City                     @relation(fields: [cityId], references: [id])
  zone                     Zone                     @relation(fields: [zoneId], references: [id])
  category                 Category?                @relation("PrimaryShopCategory", fields: [categoryId], references: [id])
  approvedBy               User?                    @relation("ShopApprovedBy", fields: [approvedById], references: [id])
  products                 Product[]
  categories               ShopCategory[]
  categoryCommissions      ShopCategoryCommission[]
  documents                ShopDocument[]
  orders                   Order[]
  reviews                  Review[]
  itemRequests             ItemRequest[]
  itemRequestQuotes        ItemRequestQuote[]
  verificationDocuments    VerificationDocument[]   @relation("ShopVerificationDocuments")
  shopRiders               ShopRider[]

  @@unique([cityId, slug])
  @@index([ownerId])
  @@index([cityId, zoneId])
  @@index([status])
  @@index([cityId, zoneId, status])
  @@index([categoryId, status])
  @@index([verificationStatus])
  @@index([deliveryMode, status])
}

model Category {
  id                       String                   @id @default(cuid())
  name                     String
  slug                     String                   @unique
  parentId                 String?
  defaultCommissionPercent Decimal                  @default(10) @db.Decimal(5, 2)
  isActive                 Boolean                  @default(true)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  parent                   Category?                @relation("CategoryTree", fields: [parentId], references: [id])
  children                 Category[]               @relation("CategoryTree")
  primaryShops             Shop[]                   @relation("PrimaryShopCategory")
  products                 Product[]
  shops                    ShopCategory[]
  shopCommissions          ShopCategoryCommission[]

  @@index([parentId])
  @@index([isActive])
}

model ShopDocument {
  id               String             @id @default(cuid())
  shopId           String
  type             ShopDocumentType
  fileUrl          String
  status           ShopDocumentStatus @default(PENDING)
  rejectionReason  String?
  reviewNotes      String?
  requestedChanges String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  shop             Shop               @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([type, status])
}

model VerificationDocument {
  id               String                        @id @default(cuid())
  ownerType        VerificationDocumentOwnerType
  shopId           String?
  riderProfileId   String?
  shopRiderId      String?
  productId        String?
  type             VerificationDocumentType
  fileUrl          String
  originalName     String?
  mimeType         String?
  sizeBytes        Int?
  status           VerificationDocumentStatus    @default(PENDING)
  rejectionReason  String?
  reviewNotes      String?
  requestedChanges String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  shop             Shop?                         @relation("ShopVerificationDocuments", fields: [shopId], references: [id])
  riderProfile     RiderProfile?                 @relation("RiderVerificationDocuments", fields: [riderProfileId], references: [id])
  shopRider        ShopRider?                    @relation("ShopRiderVerificationDocuments", fields: [shopRiderId], references: [id])
  product          Product?                      @relation("ProductVerificationDocuments", fields: [productId], references: [id])
  reviewedBy       User?                         @relation(fields: [reviewedById], references: [id])

  @@index([ownerType, type, status])
  @@index([shopId, status])
  @@index([riderProfileId, status])
  @@index([shopRiderId, status])
  @@index([productId])
}

model ShopCategory {
  shopId     String
  categoryId String
  createdAt  DateTime @default(now())
  shop       Shop     @relation(fields: [shopId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([shopId, categoryId])
}

model ShopCategoryCommission {
  id                String   @id @default(cuid())
  shopId            String
  categoryId        String
  commissionPercent Decimal  @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  shop              Shop     @relation(fields: [shopId], references: [id])
  category          Category @relation(fields: [categoryId], references: [id])

  @@unique([shopId, categoryId])
  @@index([categoryId])
}

model Product {
  id                    String                 @id @default(cuid())
  shopId                String
  categoryId            String
  name                  String
  slug                  String
  description           String?
  price                 Decimal                @db.Decimal(10, 2)
  mrp                   Decimal?               @db.Decimal(10, 2)
  stock                 Int                    @default(0)
  unit                  String                 @default("piece")
  imageUrl              String?
  status                ProductStatus          @default(ACTIVE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  shop                  Shop                   @relation(fields: [shopId], references: [id])
  category              Category               @relation(fields: [categoryId], references: [id])
  orderItems            OrderItem[]
  verificationDocuments VerificationDocument[] @relation("ProductVerificationDocuments")

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([categoryId])
  @@index([status])
  @@index([shopId, categoryId, status])
  @@index([shopId, status])
}

model RiderProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  cityId                String
  zoneId                String?
  fullName              String?
  phone                 String?
  email                 String?
  status                RiderStatus              @default(PENDING_APPROVAL)
  availabilityStatus    RiderAvailabilityStatus  @default(OFFLINE)
  vehicleType           String?
  vehicleNumber         String?
  aadhaarUrl            String?
  panUrl                String?
  drivingLicenseUrl     String?
  vehicleRcUrl          String?
  insuranceUrl          String?
  selfieUrl             String?
  profilePhotoUrl       String?
  upiId                 String?
  bankAccount           String?
  emergencyName         String?
  emergencyPhone        String?
  currentLatitude       Decimal?                 @db.Decimal(10, 7)
  currentLongitude      Decimal?                 @db.Decimal(10, 7)
  lastAvailableAt       DateTime?
  approvedById          String?
  approvedAt            DateTime?
  rejectionReason       String?
  reviewNotes           String?
  changesRequestedAt    DateTime?
  submittedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  user                  User                     @relation(fields: [userId], references: [id])
  city                  City                     @relation(fields: [cityId], references: [id])
  zone                  Zone?                    @relation(fields: [zoneId], references: [id])
  approvedBy            User?                    @relation("RiderApprovedBy", fields: [approvedById], references: [id])
  deliveries            Delivery[]
  assignedOrders        Order[]                  @relation("AssignedRiderOrders")
  assignmentAttempts    RiderAssignmentAttempt[]
  verificationDocuments VerificationDocument[]   @relation("RiderVerificationDocuments")
  shopRiders            ShopRider[]

  @@index([phone])
  @@index([cityId, zoneId, status])
  @@index([availabilityStatus, zoneId])
  @@index([status, availabilityStatus])
}

model ShopRider {
  id                    String                 @id @default(cuid())
  shopId                String
  userId                String?
  riderProfileId        String?
  fullName              String
  phone                 String
  email                 String?
  status                ShopRiderStatus        @default(DRAFT)
  vehicleType           String?
  vehicleNumber         String?
  aadhaarUrl            String?
  panUrl                String?
  drivingLicenseUrl     String?
  vehicleRcUrl          String?
  insuranceUrl          String?
  selfieUrl             String?
  profilePhotoUrl       String?
  upiId                 String?
  bankAccount           String?
  emergencyName         String?
  emergencyPhone        String?
  approvedById          String?
  approvedAt            DateTime?
  rejectionReason       String?
  reviewNotes           String?
  changesRequestedAt    DateTime?
  submittedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  shop                  Shop                   @relation(fields: [shopId], references: [id])
  user                  User?                  @relation(fields: [userId], references: [id])
  riderProfile          RiderProfile?          @relation(fields: [riderProfileId], references: [id])
  verificationDocuments VerificationDocument[] @relation("ShopRiderVerificationDocuments")

  @@unique([shopId, phone])
  @@index([shopId, status])
  @@index([phone])
  @@index([riderProfileId])
}

model Order {
  id                 String                   @id @default(cuid())
  orderNumber        String                   @unique
  customerId         String
  shopId             String
  riderId            String?
  addressId          String
  status             OrderStatus              @default(PLACED)
  paymentMethod      PaymentMethod            @default(COD)
  paymentStatus      PaymentStatus            @default(PENDING)
  subtotal           Decimal                  @db.Decimal(10, 2)
  deliveryFee        Decimal                  @default(0) @db.Decimal(10, 2)
  platformFee        Decimal                  @default(0) @db.Decimal(10, 2)
  discountAmount     Decimal                  @default(0) @db.Decimal(10, 2)
  totalAmount        Decimal                  @db.Decimal(10, 2)
  commissionPercent  Decimal                  @default(10) @db.Decimal(5, 2)
  commissionAmount   Decimal                  @default(0) @db.Decimal(10, 2)
  customerNote       String?
  cancellationReason String?
  assignedAt         DateTime?
  assignmentAttempts Int                      @default(0)
  lastAssignmentAt   DateTime?
  placedAt           DateTime                 @default(now())
  deliveredAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  customer           User                     @relation("CustomerOrders", fields: [customerId], references: [id])
  shop               Shop                     @relation(fields: [shopId], references: [id])
  rider              RiderProfile?            @relation("AssignedRiderOrders", fields: [riderId], references: [id])
  address            Address                  @relation(fields: [addressId], references: [id])
  items              OrderItem[]
  delivery           Delivery?
  payment            Payment?
  review             Review?
  assignmentHistory  RiderAssignmentAttempt[]

  @@index([customerId])
  @@index([shopId])
  @@index([riderId])
  @@index([status])
  @@index([placedAt])
  @@index([customerId, status])
  @@index([shopId, status])
  @@index([riderId, status])
  @@index([shopId, riderId, status])
  @@index([status, assignmentAttempts])
  @@index([assignedAt])
}

model RiderAssignmentAttempt {
  id         String                       @id @default(cuid())
  orderId    String
  riderId    String
  status     RiderAssignmentAttemptStatus @default(OFFERED)
  reason     String?
  distanceKm Decimal?                     @db.Decimal(10, 3)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  order      Order                        @relation(fields: [orderId], references: [id])
  rider      RiderProfile                 @relation(fields: [riderId], references: [id])

  @@index([orderId])
  @@index([riderId, status])
  @@index([orderId, riderId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Delivery {
  id          String         @id @default(cuid())
  orderId     String         @unique
  riderId     String?
  status      DeliveryStatus @default(PENDING)
  pickupOtp   String?
  dropOtp     String?
  assignedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  order       Order          @relation(fields: [orderId], references: [id])
  rider       RiderProfile?  @relation(fields: [riderId], references: [id])

  @@index([riderId])
  @@index([status])
  @@index([riderId, status])
  @@index([status, createdAt])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  provider          String?
  providerPaymentId String?
  amount            Decimal       @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id])

  @@index([status])
  @@index([method, status])
  @@index([providerPaymentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  channel   String    @default("IN_APP")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  orderId   String   @unique
  shopId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId])
}

model ItemRequest {
  id           String             @id @default(cuid())
  customerId   String
  cityId       String
  zoneId       String?
  shopId       String?
  description  String
  status       ItemRequestStatus  @default(OPEN)
  quotedAmount Decimal?           @db.Decimal(10, 2)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  customer     User               @relation(fields: [customerId], references: [id])
  city         City               @relation(fields: [cityId], references: [id])
  zone         Zone?              @relation(fields: [zoneId], references: [id])
  shop         Shop?              @relation(fields: [shopId], references: [id])
  quotes       ItemRequestQuote[]

  @@index([customerId])
  @@index([cityId, zoneId])
  @@index([status])
  @@index([shopId, status])
  @@index([cityId, zoneId, status])
}

model ItemRequestQuote {
  id            String      @id @default(cuid())
  itemRequestId String
  shopId        String?
  status        QuoteStatus @default(DRAFT)
  amount        Decimal     @db.Decimal(10, 2)
  note          String?
  expiresAt     DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  itemRequest   ItemRequest @relation(fields: [itemRequestId], references: [id])
  shop          Shop?       @relation(fields: [shopId], references: [id])

  @@index([itemRequestId, status])
  @@index([shopId, status])
  @@index([expiresAt])
}
